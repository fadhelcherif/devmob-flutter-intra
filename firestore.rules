rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    function isChatParticipant() {
      return signedIn() && request.auth.uid in resource.data.participants;
    }

    function isChatParticipantById(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isSelf(userId)
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSelf(userId);
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && (
          !('groupId' in request.resource.data)
          || request.resource.data.groupId == null
          || request.resource.data.groupId == ''
          || isGroupMember(request.resource.data.groupId)
        );
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.postId == postId;
        allow update: if signedIn() && resource.data.userId == request.auth.uid;
        allow delete: if signedIn()
          && (
            resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/posts/$(postId)).data.userId == request.auth.uid
          );
      }
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;
      allow update: if signedIn();
      allow delete: if signedIn() && resource.data.createdBy == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read, update: if isChatParticipant();
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatParticipantById(chatId);
        allow create: if isChatParticipantById(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.chatId == chatId;
        allow update, delete: if isChatParticipantById(chatId);
      }
    }
  }
}